<header class="site-header">
  <div class="container">
    <h1 class="logo"><a href="/">CSE Motors</a></h1>

    <div class="auth-links">
      <% if (account) { %>
        <span>👋 <%= account.account_firstname || account.first_name %></span>
        <a href="/account/management">Dashboard</a>
        <a href="/account/logout" class="logout">Logout</a>
      <% } else { %>
        <a href="/account/login">Login</a>
        <a href="/account/register">Register</a>
      <% } %>
    </div>
  </div>
</header>

