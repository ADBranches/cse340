<section class="vehicle-details" aria-labelledby="vehicle-name">
  <header class="section-header">
    <h2 id="vehicle-name">
      <%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %>
    </h2>
    <p>Explore specifications, features, and pricing.</p>
  </header>

  <div class="vehicle-details__layout">
    <!-- IMAGE -->
    <figure class="vehicle-details__image">
      <img 
        src="<%= vehicle.imageUrl || '/images/placeholder-car.svg' %>"
        alt="<%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %>"
        loading="lazy"
      />
    </figure>

    <!-- RIGHT COLUMN -->
    <div class="vehicle-details__info">
      <h3><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></h3>
      
      <% if (vehicle.price) { %>
        <p><strong>Price:</strong> $<%= vehicle.price.toLocaleString() %></p>
      <% } %>
      
      <% if (vehicle.color) { %>
        <p><strong>Color:</strong> <%= vehicle.color %></p>
      <% } %>
      
      <% if (vehicle.miles) { %>
        <p><strong>Mileage:</strong> <%= vehicle.miles.toLocaleString() %> miles</p>
      <% } %>

      <p class="description">
        <%= vehicle.description %>
      </p>

      <ul>
        <li>Smooth engine performance</li>
        <li>High fuel efficiency</li>
        <li>Premium comfort interior</li>
        <li>Advanced safety suite</li>
      </ul>
      
      <a href="/inventory" class="btn-secondary">← Back to Inventory</a>
    </div>
  </div>
</section>