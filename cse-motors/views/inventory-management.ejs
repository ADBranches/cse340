<section class="management-wrapper">
  <h1 class="page-title">Inventory Management Dashboard</h1>
  <p class="intro-text">
    Welcome to the CSE Motors Management Panel.  
    From here, you can organize your vehicle inventory and classification records.
  </p>

  <% if (messages && messages.length) { %>
    <div class="alert alert-success">
      <%= messages %>
    </div>
  <% } %>

  <div class="actions-box">
    <h2>Available Actions</h2>
    <ul>
      <li>➕ <a href="/inv/add-classification">Add New Classification</a></li>
      <li>🚗 <a href="/inv/add-inventory">Add New Inventory Item</a></li>
    </ul>
    <p style="margin-top:1rem;">
      <a href="/inventory" style="color:#4B0082;text-decoration:none;">← View All Vehicles</a>
    </p>
  </div>
</section>

<style>
  .management-wrapper {
    max-width: 720px;
    margin: 2rem auto;
    background: #fff;
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 6px 16px rgba(0,0,0,0.08);
  }

  .actions-box ul {
    margin-top: 1rem;
    padding-left: 1.3rem;
  }

  .actions-box a {
    color: #4B0082;
    font-weight: 600;
    font-size: 1.1rem;
    text-decoration: none;
  }

  .actions-box a:hover {
    text-decoration: underline;
  }
</style>
