<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head", { title }) %>
  <body>
    <%- include("partials/header") %>
    <%- include("partials/nav") %>

    <main id="main-content">
      <!-- Support both 'body' and 'view' variables for backward compatibility -->
      <% if (typeof body !== 'undefined') { %>
        <h2 style="color:orange;">DEBUG: Using BODY content</h2>
        <%- body %>

      <% } else if (typeof view !== 'undefined') { %>
        <!-- <h2 style="color:green;">DEBUG: Including VIEW = "<%= view %>"</h2> -->
        <%- include(view) %>

      <% } else { %>
        <h2 style="color:red;">DEBUG: NO VIEW PROVIDED</h2>
        <p>Error: No content provided for this page.</p>
      <% } %>

    </main>

    <%- include("partials/footer") %>
  </body>
</html>