<section class="error-page">
  <h2>Something went wrong.</h2>
  <p>We encountered an unexpected error while processing your request.</p>
  <% if (typeof message !== "undefined" && message) { %>
    <p><small>Error details: <%= message %></small></p>
  <% } %>
  <div class="error-actions">
    <a href="/" class="btn btn-primary">Back to CSE Motors Home</a>
    <a href="/inv/add-inventory" class="btn btn-secondary">Try Adding Inventory Again</a>
  </div>

</section>
