<%- include('../partials/head') %>
<link rel="stylesheet" href="/css/account-management.css">

<main class="management-page">
  <section class="management-container">
    <!-- Flash messages -->
    <% if (notices && notices.length) { %>
      <div class="flash flash-success"><%= notices.join('<br>') %></div>
    <% } %>
    <% if (errors && errors.length) { %>
      <div class="flash flash-error"><%= errors.join('<br>') %></div>
    <% } %>

    <!-- Greeting Section -->
    <% if (!isPrivileged) { %>
      <h1>Welcome back, <%= account.account_firstname %>!</h1>
      <p>Your client dashboard lets you manage your personal account information.</p>
    <% } else { %>
      <h1>Welcome, <%= account.account_firstname %> (<%= account.account_type %>)</h1>
      <p>You have elevated permissions to manage system data.</p>
    <% } %>

    <!-- Update Account Info -->
    <div class="management-actions">
      <a href="/account/update/<%= account.account_id %>" class="btn-primary">
        Update Account Information
      </a>
      <% if (isPrivileged) { %>
        <a href="/inv" class="btn-secondary">Go to Inventory Dashboard</a>
      <% } %>
      <a href="/account/logout" class="btn-logout">Logout</a>
    </div>
  </section>
</main>
