<%- include('../partials/head') %>

<main class="account-dashboard">
  <!-- Flash messages -->
  <% if (notices && notices.length) { %>
    <div class="alert alert-success"><%= notices.join('<br>') %></div>
  <% } %>
  <% if (errors && errors.length) { %>
    <div class="alert alert-error"><%= errors.join('<br>') %></div>
  <% } %>

  <!-- Greeting Section -->
  <% if (!isPrivileged) { %>
    <!-- Client view -->
    <h2>Welcome back, <%= account.first_name %>!</h2>
    <p>Your client dashboard lets you manage your personal account information.</p>
  <% } else { %>
    <!-- Employee / Admin view -->
    <h2>Welcome, <%= account.account_firstname %> (<%= account.account_type %>)</h2>
    <p>You have elevated permissions to manage system data.</p>
  <% } %>

  <!-- Update Account Info -->
  <section class="account-actions">
    <a href="/account/update/<%= account.account_id %>" class="btn btn-primary">
      Update Account Information
    </a>
  </section>

  <% if (isPrivileged) { %>
    <!-- Inventory Management (hidden completely for Clients) -->
    <section class="inventory-access">
      <h3>Inventory Management</h3>
      <p>Manage vehicles, classifications, and availability listings.</p>
      <a href="/inv" class="btn btn-secondary">Go to Inventory Dashboard</a>
    </section>
  <% } %>

  <section class="logout-link">
    <a href="/account/logout" class="btn btn-logout">Logout</a>
  </section>
</main>

<style>
  .account-dashboard {
    max-width: 800px;
    margin: 2rem auto;
    padding: 1rem;
    background: #f9f9f9;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,.1);
  }
  .account-actions, .inventory-access, .logout-link {
    margin-top: 1.5rem;
  }
  .btn {
    display: inline-block;
    padding: 10px 20px;
    border-radius: 4px;
    text-decoration: none;
    color: #fff;
  }
  .btn-primary { background: #007bff; }
  .btn-secondary { background: #6c757d; }
  .btn-logout { background: #dc3545; }
</style>

