<section class="inventory-page" aria-labelledby="inventory-title">
  <header class="section-header">
    <h2 id="inventory-title">Available Vehicles</h2>
    <p>Browse all vehicles currently available at CSE Motors.</p>
  </header>

  <div class="featured__grid">
    <% if (items && items.length > 0) { %>
      <% items.forEach(vehicle => { %>
        <article class="vehicle-card">
          <figure>
            <img 
              src="<%= vehicle.image || '/images/placeholder-car.svg' %>" 
              alt="<%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %>" 
              loading="lazy"
            />
          </figure>

          <div class="vehicle-card__body">
            <h4><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></h4>

            <p><%= vehicle.description %></p>

            <!-- ⭐ FORMATTED PRICE -->
            <p><strong>Price:</strong> <%= utils.formatPrice(vehicle.price) %></p>

            <!-- ⭐ FORMATTED MILES -->
            <p><strong>Mileage:</strong> <%= utils.formatMiles(vehicle.miles) %></p>

            <a href="/inventory/detail/<%= vehicle.id %>" class="btn-primary">View Details</a>
          </div>
        </article>
      <% }) %>
    <% } else { %>
      <p>No vehicles currently available.</p>
    <% } %>
  </div>
</section>
