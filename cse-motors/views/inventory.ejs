<section class="inventory-page" aria-labelledby="inventory-title">
  <header class="section-header">
    <h2 id="inventory-title">Available Vehicles</h2>
    <p>Browse all vehicles currently available at CSE Motors.</p>
  </header>

  <div class="featured__grid">
    <% if (typeof items !== 'undefined' && items.length > 0) { %>
      <% items.forEach(function(item) { %>
        <article class="vehicle-card">
          <figure>
            <img src="<%= item.imageUrl || '/images/placeholder-car.svg' %>" alt="<%= item.make %> <%= item.model %>" loading="lazy" />
          </figure>
          <div class="vehicle-card__body">
            <h4><%= item.year %> <%= item.make %> <%= item.model %></h4>
            <p><%= item.description %></p>
            <a href="/inventory/detail/<%= item.id %>" class="btn-primary">
              View Details
            </a>
          </div>
        </article>
      <% }); %>
    <% } else { %>
      <p>No vehicles available at the moment.</p>
    <% } %>
  </div>
</section>